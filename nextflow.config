manifest {
    name            = 'gpu-smoke-nf'
    description     = 'GPU smoke test for the Seqera GPU-enabled AMI (COMP-1906).'
    version         = '0.1.0'
    nextflowVersion = '>=24.04.0'
    mainScript      = 'main.nf'
}

profiles {
    standard {
        docker.enabled = true
    }
    awsbatch {
        process.executor = 'awsbatch'
    }
}
